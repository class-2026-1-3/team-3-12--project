# 1. 최적화된 리눅스 기반의 Node.js 환경을 가져옵니다.
FROM node:18-alpine

# 2. 도커 내부에서 코드가 실행될 작업 디렉토리를 설정합니다.
WORKDIR /app

# 3. 라이브러리 목록 파일을 먼저 복사하고 설치합니다. (빌드 속도 최적화)
COPY package*.json ./
RUN npm install

# 4. 내 컴퓨터에 있는 나머지 소스 코드를 전부 도커 안으로 복사합니다.
COPY . .

# 5. 내 웹 서버가 사용하는 포트를 열어줍니다.
EXPOSE 3000

# 6. 도커가 켜지면 실행할 서버 시작 명령어를 적습니다.
CMD ["npm", "start"]